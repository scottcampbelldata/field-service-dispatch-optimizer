# Copy to .env and adjust as needed.

# Local default is a SQLite file (zero infrastructure).
# DATABASE_URL=sqlite:///./dispatch.db

# Production / docker-compose uses Postgres:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dispatch

# Seed for the synthetic generator (determines the canonical day).
# SEED=42

# Default solver time budget (seconds).
# DEFAULT_SOLVE_SECONDS=12

# --- Travel / routing provider ---------------------------------------------
# How travel times are computed:
#   haversine        great-circle distance (default, free, offline, reproducible)
#   openrouteservice real road durations  (bring your own free key, below)
#   osrm             real road durations  (self-hosted or public OSRM endpoint)
# Any misconfiguration or API error falls back to haversine automatically, so
# the public demo always works without secrets.
ROUTING_PROVIDER=haversine

# OpenRouteService: get a free key at https://openrouteservice.org/dev/#/signup
# Used only when ROUTING_PROVIDER=openrouteservice. NEVER commit a real key.
ORS_API_KEY=

# OSRM endpoint (self-hosted or public demo). Used only when ROUTING_PROVIDER=osrm.
# Example: https://router.project-osrm.org
OSRM_BASE_URL=

# If a scenario exceeds this many unique points, real routing is skipped and
# travel falls back to haversine (keeps quotas/latency sane).
# ROUTING_MAX_POINTS=50

# Comma-separated allowed CORS origins for the API.
# CORS_ORIGINS=http://localhost:3000

# Frontend -> API base URL (set in the frontend environment).
# NEXT_PUBLIC_API_BASE=http://localhost:8000
