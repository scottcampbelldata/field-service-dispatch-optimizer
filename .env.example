# Copy to .env and adjust as needed.

# Local default is a SQLite file (zero infrastructure).
# DATABASE_URL=sqlite:///./dispatch.db

# Production / docker-compose uses Postgres:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dispatch

# Seed for the synthetic generator (determines the canonical day).
# SEED=42

# Comma-separated allowed CORS origins for the API.
# CORS_ORIGINS=http://localhost:3000

# Frontend -> API base URL (set in the frontend environment).
# NEXT_PUBLIC_API_BASE=http://localhost:8000
